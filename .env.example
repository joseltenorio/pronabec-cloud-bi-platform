# PRONABEC Cloud BI Platform
# Plantilla de variables de entorno

# Google Cloud project settings
GCP_PROJECT_ID=your-gcp-project-id
GCP_PROJECT_NAME=your-gcp-project-id
GCP_PROJECT_NUMBER=000000000000
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
BQ_LOCATION=US
GCS_LOCATION=US

# Cloud Storage
GCS_BUCKET_NAME=your-gcs-bucket-name
GCS_BRONZE_PREFIX=bronze
GCS_DLQ_PREFIX=dlq
GCS_QUALITY_PREFIX=quality
GCS_AUDIT_PREFIX=audit
GCS_EVIDENCE_PREFIX=evidence

DLQ_LOCATION=gs://your-gcs-bucket-name/dlq
QUALITY_LOCATION=gs://your-gcs-bucket-name/quality
AUDIT_LOCATION=gs://your-gcs-bucket-name/audit
EVIDENCE_LOCATION=gs://your-gcs-bucket-name/evidence

# BigQuery datasets
BQ_BRONZE_DATASET=bronze
BQ_SILVER_DATASET=silver
BQ_GOLD_DATASET=gold
BQ_AUDIT_DATASET=audit
BQ_ML_DATASET=ml

# Artifact Registry
ARTIFACT_REGISTRY_LOCATION=us-central1
ARTIFACT_REGISTRY_REPOSITORY=pronabec-containers
ARTIFACT_IMAGE_NAME=pronabec-cloud-bi-platform
ARTIFACT_IMAGE_TAG=latest

# Pipeline settings
PIPELINE_NAME=project_cloud_bi_platform
PIPELINE_ENV=dev
DEFAULT_EXTRACTION_DATE=
LOG_LEVEL=INFO

# PRONABEC API settings
PRONABEC_API_BASE_URL=https://datosabiertos.pronabec.gob.pe/Dataset
PRONABEC_BATCH_SIZE=100
PRONABEC_MAX_REQUESTS_PER_SECOND=5

# PRONABEC reports manual/documental settings
PRONABEC_REPORTS_LOCAL_MANUAL_DIR=data/manual/pronabec_reports
PRONABEC_REPORTS_LANDING_PREFIX=landing/pronabec_reports
PRONABEC_REPORTS_BRONZE_PREFIX=bronze/pronabec_reports
PRONABEC_REPORTS_SUBSETS=pes_2025,beca18_universitarios_2012_2026
PRONABEC_REPORTS_STAGE_JOB_NAME=pronabec-stage-reports-job
GOLD_PUBLISH_JOB_NAME=gold-publish-job
GOLD_VALIDATE_JOB_NAME=gold-validate-job
SOURCE_SUBSET=pes_2025
BRONZE_EXTRACTION_DATE=

PRONABEC_REPORTS_SOURCE_DOCUMENT=7219175-panorama-de-estudios-sociales-pronabec.pdf
PRONABEC_REPORTS_SOURCE_TITLE="Panorama de Estudios Sociales del Pronabec - Volumen I"
PRONABEC_REPORTS_EXTRACTION_METHOD=pdf_table_extraction
PRONABEC_REPORTS_LOCAL_INPUT_DIR=data/manual/pronabec_reports/pes_2025

# MEF Consulta Amigable runtime settings
MEF_SOURCE_MODE=consulta_amigable
MEF_CONSULTA_AMIGABLE_BASE_URL=https://apps5.mineco.gob.pe/transparencia/Navegador/
MEF_START_YEAR=2012
MEF_END_YEAR=2026
MEF_TEXT_FILTER=PRONABEC
MEF_TIMEOUT_SECONDS=90
MEF_PRONABEC_EXECUTORA_CODE=117-1438
MEF_PRONABEC_EXECUTORA_NAME=PROGRAMA NACIONAL DE BECAS Y CREDITO EDUCATIVO
MEF_INCLUDE_HIERARCHY=true
MEF_INCLUDE_SPENDING_BREAKDOWNS=true
MEF_BREAKDOWN_SLICES=producto,generica,fuente,rubro,departamento,temporal,producto_temporal,actividad,actividad_temporal,generica_temporal

# Dataflow settings
DATAFLOW_RUNNER=DataflowRunner
DATAFLOW_TEMP_LOCATION=gs://your-gcs-bucket-name/dataflow/temp
DATAFLOW_STAGING_LOCATION=gs://your-gcs-bucket-name/dataflow/staging
DATAFLOW_SERVICE_ACCOUNT=pronabec-dataflow-sa@pronabec-cloud-bi-platform.iam.gserviceaccount.com
DATAFLOW_SETUP_FILE=/app/setup.py
DATAFLOW_WORKER_MACHINE_TYPE=n1-standard-2
DATAFLOW_MAX_NUM_WORKERS=2

# Cloud Run Jobs settings
CLOUD_RUN_REGION=us-central1
CLOUD_RUN_SERVICE_ACCOUNT=your-cloudrun-sa@your-gcp-project-id.iam.gserviceaccount.com
CLOUD_RUN_IMAGE=us-central1-docker.pkg.dev/your-gcp-project-id/pronabec-containers/pronabec-cloud-bi-platform:latest
PRONABEC_DISCOVERY_JOB_NAME=pronabec-discovery-job
PRONABEC_BUILD_PLAN_JOB_NAME=pronabec-build-plan-job
PRONABEC_RUN_PLAN_JOB_NAME=pronabec-run-plan-job
PRONABEC_EXTRACT_CHUNK_JOB_NAME=pronabec-extract-chunk-job
PRONABEC_FINALIZE_DATASET_JOB_NAME=pronabec-finalize-dataset-job

# CI/CD settings
CICD_SERVICE_ACCOUNT=your-cicd-sa@your-gcp-project-id.iam.gserviceaccount.com

# Composer settings
COMPOSER_ENVIRONMENT_NAME=project-cloud-bi-composer
COMPOSER_LOCATION=us-central1
COMPOSER_SERVICE_ACCOUNT=your-composer-sa@your-gcp-project-id.iam.gserviceaccount.com

# Quality settings
QUALITY_CHECKS_FILE=sql/quality/data_quality_checks.sql
QUALITY_FAIL_ON_ERROR=true
QUALITY_DRY_RUN=false
