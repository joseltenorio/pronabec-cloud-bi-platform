# Google Cloud project settings
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# Cloud Storage
GCS_BUCKET_NAME=project-cloud-bi-platform-lake
GCS_BRONZE_PREFIX=bronze
GCS_SILVER_PREFIX=silver
GCS_GOLD_PREFIX=gold
GCS_DLQ_PREFIX=dlq

# BigQuery datasets
BQ_BRONZE_DATASET=bronze
BQ_SILVER_DATASET=silver
BQ_GOLD_DATASET=gold
BQ_AUDIT_DATASET=audit
BQ_ML_DATASET=ml

# Pipeline settings
PIPELINE_NAME=project_cloud_bi_platform
PIPELINE_ENV=dev
DEFAULT_EXTRACTION_DATE=
LOG_LEVEL=INFO

# PRONABEC API settings
PRONABEC_API_BASE_URL=https://datosabiertos.pronabec.gob.pe/Dataset
PRONABEC_BATCH_SIZE=100
PRONABEC_MAX_REQUESTS_PER_SECOND=5

# MEF scraper settings
MEF_START_YEAR=2012
MEF_END_YEAR=2026
MEF_REQUEST_TIMEOUT_SECONDS=60

# Dataflow settings
DATAFLOW_TEMP_LOCATION=gs://project-cloud-bi-platform-lake/temp/dataflow
DATAFLOW_STAGING_LOCATION=gs://project-cloud-bi-platform-lake/staging/dataflow
DATAFLOW_SERVICE_ACCOUNT=
DATAFLOW_WORKER_MACHINE_TYPE=n1-standard-2
DATAFLOW_MAX_NUM_WORKERS=2

# Composer settings
COMPOSER_ENVIRONMENT_NAME=project-cloud-bi-composer
COMPOSER_LOCATION=us-central1